# 이 파일을 .env로 복사한 뒤 값을 채우세요: cp .env.example .env
# .env는 .gitignore에 이미 포함되어 있으므로 커밋되지 않습니다.

# KB증권 OpenAPI 운영 서버 주소 (보통 바꿀 필요 없음)
KB_OPENAPI_BASE_URL=https://developer.kbsec.com:32484

# KB OpenAPI 포털(https://developer.kbsec.com)에서 앱 등록 후 발급받은 값
KB_OPENAPI_CLIENT_ID=발급받은_clientId를_입력하세요
KB_OPENAPI_CLIENT_SECRET=발급받은_clientSecret을_입력하세요
