# Backend URL used by Next.js rewrites.
NEXT_PUBLIC_API_URL=http://localhost:8020

# Production only.
NEXT_PUBLIC_OPENAPI_MODE=production

# Frontend fallback values. The backend /api/config/runtime response is preferred at runtime.
NEXT_PUBLIC_OPENAPI_PROD_KB_B2C_BASE_URL=https://developer.kbsec.com:32484
NEXT_PUBLIC_OPENAPI_PROD_KB_B2C_TOKEN_BASE_URL=https://developer.kbsec.com:32484
